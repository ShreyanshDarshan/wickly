# =============================================================================
# wickly — .gitignore
# =============================================================================

# -----------------------------------------------------------------------------
# Python
# -----------------------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.pyo
*.pyd

# C extensions
*.so
*.pyd

# -----------------------------------------------------------------------------
# Distribution / packaging
# -----------------------------------------------------------------------------
*.egg
*.egg-info/
dist/
build/
wheels/
sdist/
MANIFEST
.eggs/
pip-wheel-metadata/

# -----------------------------------------------------------------------------
# Virtual environments
# -----------------------------------------------------------------------------
.env
.venv
env/
venv/
ENV/
env.bak/
venv.bak/

# Conda
.conda/

# -----------------------------------------------------------------------------
# Testing
# -----------------------------------------------------------------------------
.pytest_cache/
.tox/
.nox/
htmlcov/
.coverage
.coverage.*
coverage.xml
*.cover
*.py,cover
nosetests.xml
pytest.xml

# -----------------------------------------------------------------------------
# Type checking
# -----------------------------------------------------------------------------
.mypy_cache/
.dmypy.json
dmypy.json
.pytype/

# -----------------------------------------------------------------------------
# Sphinx documentation
# -----------------------------------------------------------------------------
docs/_build/
docs/generated/

# -----------------------------------------------------------------------------
# Jupyter Notebooks
# -----------------------------------------------------------------------------
.ipynb_checkpoints/
*.ipynb

# -----------------------------------------------------------------------------
# PyQt / Qt artifacts
# -----------------------------------------------------------------------------
*.ui.bak
*.qrc.bak

# -----------------------------------------------------------------------------
# OS-generated files
# -----------------------------------------------------------------------------

# macOS
.DS_Store
.AppleDouble
.LSOverride
._*
.Spotlight-V100
.Trashes

# Windows
Thumbs.db
Thumbs.db:encryptable
ehthumbs.db
ehthumbs_vista.db
Desktop.ini
$RECYCLE.BIN/
*.lnk

# Linux
*~

# -----------------------------------------------------------------------------
# IDEs & editors
# -----------------------------------------------------------------------------

# VS Code
.vscode/
!.vscode/extensions.json

# JetBrains (PyCharm, etc.)
.idea/
*.iws
*.iml
*.ipr

# Vim / Emacs
*.swp
*.swo
*~
\#*\#
.\#*

# Sublime Text
*.sublime-workspace

# -----------------------------------------------------------------------------
# Miscellaneous
# -----------------------------------------------------------------------------
*.log
*.tmp
*.bak
*.orig
.cache/
